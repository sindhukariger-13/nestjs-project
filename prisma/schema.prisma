generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  schedulingType  SchedulingType

  slots           Slot[]
  waves           Wave[]
}

model Slot {
  id         String   @id @default(uuid())
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id])

  startTime  DateTime
  endTime    DateTime

  isBooked   Boolean  @default(false)
}

model Wave {
  id          String   @id @default(uuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id])

  startTime   DateTime
  endTime     DateTime

  capacity    Int
  bookedCount Int      @default(0)
}

enum SchedulingType {
  WAVE
  STREAM
}