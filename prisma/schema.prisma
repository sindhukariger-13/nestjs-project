generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SchedulingType {
  WAVE
  STREAM
}

model Doctor {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  schedulingType  SchedulingType
  address         String?
  consultationFee Int?

  slots           Slot[]
  waves           Wave[]
  schedule        DoctorSchedule?
  appointments    Appointment[]
}

model Slot {
  id          String       @id @default(uuid())

  doctorId    String
  doctor      Doctor       @relation(fields: [doctorId], references: [id])

  startTime   DateTime
  endTime     DateTime

  isBooked    Boolean      @default(false)

  appointment Appointment?
}

model Wave {
  id            String         @id @default(uuid())

  doctorId      String
  doctor        Doctor         @relation(fields: [doctorId], references: [id])

  startTime     DateTime
  endTime       DateTime

  capacity      Int
  bookedCount   Int            @default(0)

  appointments  Appointment[]
}

model DoctorSchedule {
  id            String   @id @default(uuid())

  doctorId      String   @unique
  workingDays   String[]
  startTime     String
  endTime       String
  slotDuration  Int

  doctor        Doctor   @relation(fields: [doctorId], references: [id])
}

model DoctorLeave {
  id          String    @id @default(uuid())

  doctorId    String
  startDate   DateTime
  endDate     DateTime
}

model ClinicHoliday {
  id        String    @id @default(uuid())

  date      DateTime
  reason    String?
}

model Appointment {
  id               String    @id @default(uuid())

  doctorId         String
  doctor           Doctor    @relation(fields: [doctorId], references: [id])

  patientId        String

  // STREAM BOOKING
  slotId           String?   @unique
  slot             Slot?     @relation(fields: [slotId], references: [id])

  // WAVE BOOKING
  waveId           String?
  wave             Wave?     @relation(fields: [waveId], references: [id])

  // OPTIONAL IDEMPOTENCY
  idempotencyKey   String?   @unique

  date             DateTime

  createdAt        DateTime  @default(now())

  @@index([doctorId, date])
}